{
  "name": "steam-workshop-ts",
  "version": "1.0.1",
  "type": "module",
  "description": "Zero-dependency TypeScript client for the Steam Workshop Web API and SteamCMD, for Node.js and Bun. Query and search workshop items, resolve collections, and download/update items with caching, disk-space checks and a CLI.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "steam-workshop-ts": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src test examples --max-warnings 0",
    "lint:fix": "eslint src test examples --fix",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "dev": "tsup --watch",
    "clean": "bun -e \"import{rmSync}from'fs';try{rmSync('dist',{recursive:true,force:true})}catch{}\"",
    "prepublishOnly": "bun run clean && bun run type-check && bun run lint && bun run build"
  },
  "keywords": [
    "steam",
    "steam-workshop",
    "workshop",
    "steamcmd",
    "workshop-downloader",
    "steam-web-api",
    "steam-api",
    "steamworks",
    "published-file",
    "valve",
    "source-engine",
    "source2",
    "counter-strike",
    "cs2",
    "csgo",
    "gmod",
    "garrys-mod",
    "dota2",
    "modding",
    "gamedev",
    "game-server",
    "cli",
    "nodejs",
    "bun",
    "typescript",
    "api-client",
    "zero-dependency"
  ],
  "author": "Kőrösfalvi \"K4ryuu\" Martin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/K4ryuu/steam-workshop-ts.git"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "bun-types": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "sideEffects": false
}
